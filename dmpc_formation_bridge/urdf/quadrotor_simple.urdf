<?xml version="1.0"?>
<!-- Simple Quadrotor for visualization only (no physics plugins) -->
<robot name="quadrotor">
  <link name="base_link">
    <pose>0 0 0 0 0 0</pose>
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="0.5 0.5 0.1"/>
      </geometry>
      <material name="blue">
        <color rgba="0.5 0.5 0.9 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="0.5 0.5 0.1"/>
      </geometry>
    </collision>
  </link>

  <!-- Four arms -->
  <link name="arm_fl">
    <pose>0.18 0.18 -0.02 0 0 0</pose>
    <inertial><mass value="0.05"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
    <visual><geometry><cylinder radius="0.02" length="0.25"/></geometry><material name="gray"><color rgba="0.5 0.5 0.5 1.0"/></material></visual>
    <collision><geometry><cylinder radius="0.02" length="0.25"/></collision>
  </link>
  <link name="arm_fr">
    <pose>0.18 -0.18 -0.02 0 0 0</pose>
    <inertial><mass value="0.05"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
    <visual><geometry><cylinder radius="0.02" length="0.25"/></geometry><material name="gray"><color rgba="0.5 0.5 0.5 1.0"/></material></visual>
    <collision><geometry><cylinder radius="0.02" length="0.25"/></collision>
  </link>
  <link name="arm_bl">
    <pose>-0.18 0.18 -0.02 0 0 0</pose>
    <inertial><mass value="0.05"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
    <visual><geometry><cylinder radius="0.02" length="0.25"/></geometry><material name="gray"><color rgba="0.5 0.5 0.5 1.0"/></material></visual>
    <collision><geometry><cylinder radius="0.02" length="0.25"/></collision>
  </link>
  <link name="arm_br">
    <pose>-0.18 -0.18 -0.02 0 0 0</pose>
    <inertial><mass value="0.05"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
    <visual><geometry><cylinder radius="0.02" length="0.25"/></geometry><material name="gray"><color rgba="0.5 0.5 0.5 1.0"/></material></visual>
    <collision><geometry><cylinder radius="0.02" length="0.25"/></collision>
  </link>

  <!-- Motors (spheres) -->
  <link name="motor_fl"><pose>0.25 0.25 0 0 0 0</pose><inertial><mass value="0.02"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial><visual><geometry><sphere radius="0.05"/></geometry><material name="darkgray"><color rgba="0.2 0.2 0.2 1.0"/></material></visual><collision><geometry><sphere radius="0.05"/></collision></link>
  <link name="motor_fr"><pose>0.25 -0.25 0 0 0 0</pose><inertial><mass value="0.02"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial><visual><geometry><sphere radius="0.05"/></geometry><material name="darkgray"><color rgba="0.2 0.2 0.2 1.0"/></material></visual><collision><geometry><sphere radius="0.05"/></collision></link>
  <link name="motor_bl"><pose>-0.25 0.25 0 0 0 0</pose><inertial><mass value="0.02"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial><visual><geometry><sphere radius="0.05"/></geometry><material name="darkgray"><color rgba="0.2 0.2 0.2 1.0"/></material></visual><collision><geometry><sphere radius="0.05"/></collision></link>
  <link name="motor_br"><pose>-0.25 -0.25 0 0 0 0</pose><inertial><mass value="0.02"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial><visual><geometry><sphere radius="0.05"/></geometry><material name="darkgray"><color rgba="0.2 0.2 0.2 1.0"/></material></visual><collision><geometry><sphere radius="0.05"/></collision></link>

  <joint name="base_to_fl" type="fixed"><parent link="base_link"/><child link="arm_fl"/></joint>
  <joint name="base_to_fr" type="fixed"><parent link="base_link"/><child link="arm_fr"/></joint>
  <joint name="base_to_bl" type="fixed"><parent link="base_link"/><child link="arm_bl"/></joint>
  <joint name="base_to_br" type="fixed"><parent link="base_link"/><child link="arm_br"/></joint>
  <joint name="arm_to_motor_fl" type="fixed"><parent link="arm_fl"/><child link="motor_fl"/></joint>
  <joint name="arm_to_motor_fr" type="fixed"><parent link="arm_fr"/><child link="motor_fr"/></joint>
  <joint name="arm_to_motor_bl" type="fixed"><parent link="arm_bl"/><child link="motor_bl"/></joint>
  <joint name="arm_to_motor_br" type="fixed"><parent link="arm_br"/><child link="motor_br"/></joint>
</robot>
